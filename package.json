{
  "name": "sourcing-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "rollup --config",
    "obfu": "javascript-obfuscator build/index.js --output build/index.js --dead-code-injection true --split-strings true --string-array-calls-transform true",
    "deploy:dev": "yarn build && yarn obfu && cross-env clasp_config_project=.clasp.json.dev clasp push",
    "deploy:prod": "yarn build && yarn obfu && cross-env clasp_config_project=.clasp.json.prod clasp push",
    "lint": "eslint --fix --quiet 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'"
  },
  "type": "module",
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.21.4",
    "@babel/plugin-transform-runtime": "^7.21.4",
    "@babel/preset-env": "^7.21.4",
    "@babel/preset-typescript": "^7.21.4",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.38.0",
    "@google/clasp": "^2.4.2",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-babel": "^6.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@types/google-apps-script": "^1.0.60",
    "@types/node": "^24.3.1",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.46.1",
    "baseline-browser-mapping": "^2.10.0",
    "cross-env": "^10.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.4.0",
    "javascript-obfuscator": "^4.1.1",
    "prettier": "^3.0.0",
    "rollup": "^4.9.2",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "moment": "^2.29.4"
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": "current"
          }
        }
      ],
      "@babel/preset-typescript"
    ],
    "plugins": [
      [
        "@babel/plugin-transform-runtime",
        {
          "regenerator": true
        }
      ]
    ]
  }
}
